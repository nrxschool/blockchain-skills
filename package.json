{
  "name": "@nearx/skills-monorepo",
  "version": "0.1.0",
  "author": "Nearx",
  "license": "MIT",
  "private": true,
  "type": "module",
  "description": "Stellar Network AI agent skills for the Nearx developer community",
  "workspaces": [
    "packages/*",
    "libs/*"
  ],
  "engines": {
    "node": ">=24"
  },
  "bugs": {
    "url": "https://github.com/nearxdev/skills/issues"
  },
  "homepage": "https://github.com/nearxdev/skills#readme",
  "scripts": {
    "build": "nx run-many -t build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:skill": "nx g @nearx/skill-plugin:skill",
    "generate:data": "nx run-many -t generate-data --output-style=stream",
    "generate:registry": "nx run @nearx/skills-catalog:generate-registry",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm run scan",
    "release": "npm run scan && nx release",
    "release:beta": "npm run scan && nx release --preid beta",
    "release:beta:dry": "nx release --preid beta --dry-run",
    "release:dry": "nx release --dry-run",
    "scan": "npx nx run @nearx/skills-catalog:security-scan",
    "validate": "npx tsx tools/validate-skills.ts --batch packages/skills-catalog/skills",
    "start:dev:cli": "npm run dev --workspace=@nearx/skills-cli",
    "start:dev:mcp": "npm run start:dev --workspace=@nearx/skills-mcp",
    "test": "cross-env NODE_OPTIONS='--experimental-vm-modules' nx run-many -t test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nearxdev/skills.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "agents",
    "ai",
    "blockchain",
    "claude-code",
    "cli",
    "copilot",
    "cursor",
    "nearx",
    "skills",
    "soroban",
    "stellar",
    "web3"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@modelcontextprotocol/inspector": "^0.21.1",
    "@nx/devkit": "^22.5.4",
    "@nx/esbuild": "^22.5.4",
    "@nx/eslint": "^22.5.4",
    "@nx/eslint-plugin": "^22.5.4",
    "@nx/jest": "22.5.4",
    "@nx/js": "^22.5.4",
    "@nx/next": "^22.5.4",
    "@nx/node": "^22.5.4",
    "@nx/plugin": "^22.5.4",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "1.15.18",
    "@swc/helpers": "~0.5.19",
    "@types/jest": "^30.0.0",
    "@types/node": "^24",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.6.0",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "jest-util": "^30.3.0",
    "jsonc-eslint-parser": "^2.4.2",
    "next": "~16.1.6",
    "nx": "^22.5.4",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "yaml": "^2.8.2"
  },
  "nx": {
    "includedScripts": []
  }
}